{
  "version": "1.0.0",
  "rootDir": "./",
  "include": ["app/**", "pages/**", "src/**", "lib/**", "components/**"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.stories.tsx",
    "**/node_modules/**",
    "**/.next/**",
    "**/dist/**"
  ],
  "layers": [
    {
      "name": "UI",
      "patterns": ["**/app/**/page.tsx", "**/pages/**", "**/components/**"],
      "color": "#3B82F6"
    },
    {
      "name": "API",
      "patterns": ["**/app/api/**", "**/pages/api/**"],
      "color": "#10B981"
    },
    {
      "name": "Processing",
      "patterns": ["**/lib/**", "**/utils/**", "**/services/**"],
      "color": "#F59E0B"
    },
    {
      "name": "Data",
      "patterns": ["**/prisma/**", "**/db/**", "**/models/**"],
      "color": "#8B5CF6"
    }
  ],
  "domains": [
    {
      "name": "Risk",
      "patterns": ["**/risk/**", "**/components/risk-**"],
      "critical": true
    },
    {
      "name": "Weather",
      "patterns": ["**/weather/**", "**/radar/**"]
    },
    {
      "name": "Hydrology",
      "patterns": ["**/hydrology/**"]
    },
    {
      "name": "Auth",
      "patterns": ["**/auth/**", "**/login/**"]
    }
  ],
  "externalServices": [
    {
      "name": "OpenWeather API",
      "patterns": ["api.openweathermap.org", "openweathermap"],
      "type": "REST API"
    },
    {
      "name": "PostgreSQL",
      "patterns": ["@prisma/client", "prisma"],
      "type": "Database"
    },
    {
      "name": "INEA API",
      "patterns": ["inea", "inea.rj.gov.br"],
      "type": "REST API"
    }
  ],
  "output": {
    "formats": ["markdown", "png"],
    "directory": "./docs/architecture",
    "simplified": true,
    "detailed": true
  },
  "plugins": []
}
